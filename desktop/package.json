{
  "name": "enterprise-agent-hub-desktop",
  "version": "0.1.0-m6",
  "private": true,
  "description": "Enterprise Agent Hub desktop backend foundation for M6",
  "main": "dist/main/main.js",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node scripts/lint.mjs",
    "test": "vitest run",
    "test:electron": "npm run build && electron tests/electron-runtime-smoke.cjs && vitest run tests/electron-smoke.test.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "npm run build && electron dist/main/main.js"
  },
  "dependencies": {
    "electron": "42.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sql.js": "1.14.1",
    "vite": "8.0.11"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sql.js": "1.4.11",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
